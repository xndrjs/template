import { branded, BrandedType } from "@xndrjs/branded";
import { z } from "zod";
import { {{baseKitId}} } from "{{baseKitImportPath}}";

/**
 * Refinement of base kit `{{baseKitId}}` → `{{refinedPascal}}`.
 */
{{#if isShape}}
const {{refinedPascal}}Schema = z.object({
  // TODO example, remove this
  // isVerified: z.literal(true),
});

type {{refinedPascal}}Candidate = BrandedType<typeof {{baseKitId}}> &
  z.input<typeof {{refinedPascal}}Schema>;
{{else}}
const {{refinedPascal}}Schema = {{primitiveSchemaExpr}};

type {{refinedPascal}}Candidate = BrandedType<typeof {{baseKitId}}> &
  z.input<typeof {{refinedPascal}}Schema>;
{{/if}}

export const {{refinedPascal}}Refinement = branded
  .refine({{baseKitId}})
  .when((value): value is {{refinedPascal}}Candidate => {
    const parsed = {{refinedPascal}}Schema.safeParse(value);
    return parsed.success;
  })
  .as("{{refinedPascal}}");

export type {{refinedPascal}} = BrandedType<typeof {{refinedPascal}}Refinement>;
